### Window theming
width = 100%
height = 100%
border-width = 0
outline-width = 0
padding-left = 35%
padding-top = 30%
result-spacing = 25
num-results = 7

# Font Config
font = "Fira Code"
font-size = 18
font-features = "liga 1"

# Color Config
text-color = #cdd6f4
prompt-color = #f38ba8
selection-color = #f9e2af
background-color = #1e1e2edd

text-cursor-style = bar     
prompt-text = "run: "       
placeholder-text = "..."    

scale = true
anchor = center

#
### Behaviour
#
	# Hide the mouse cursor
	hide-cursor = true

	# Show a text cursor in the input field
	text-cursor = true

	# Sort result by number of usages in run and drun modes
	history = true

	# Select the matching algorithm used.
	fuzzy-match = false

