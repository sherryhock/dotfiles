{
  "layer": "top",
  "position": "top",
  "spacing": 20,
  "mode": "dock",
  "exclusice": true,
  "reload_style_on_change": true,

  "modules-left": ["hyprland/workspaces", "mpris"],

  "modules-center": ["clock", "custom/weather"],

  "modules-right": [
    "tray",
    "network",
    "pulseaudio",
    "backlight",
    "battery",
    "memory",
    "cpu"
  ],

  "margin": "4 12 0 12",
  // "margin-left": 12,
  // "margin-right": 12,

  // TaskBar Config
  "wlr/taskbar": {
    "format": "{icon}",
    "rotate": 0,
    "icon-size": 18,
    "icon-theme": "Papirus-light",
    "spacing": 0,
    "tooltip-format": "{title}",
    "on-click": "activate",
    "on-click-right": "close",
    "ignore-list": ["foot"],
    "app_ids-mapping": {
      "firefoxdeveloperedition": "firefox-developer-edition"
    }
  },

  // MPRIS Config
  "mpris": {
    "interval": 60,
    "format": "{player_icon}",
    "format-playing": "{status_icon} Playing",
    "format-paused": "{status_icon} Pause",
    "tooltip-format": "{dynamic}",
    "dynamic-len": 50,
    "dynamic-importance-order": ["album", "artist", "position", "length"],
    "player-icons": {
      "default": "ΎΒΜ",
      "mpv": "ΎΞχ "
    },
    "status-icons": {
      "playing": "ΎΒΜ",
      "paused": "ΎΒΝ"
    }
  },

  // Hyprland Window Name Config
  "hyprland/window": {
    "format": "{}",
    "rotate": 0,
    "separate-outputs": true,
    "rewrite": {
      "(.*)foot": "F",
      "(.*) έΑΦ LibreWolf": " ≤░Ι╣ ",
      "(.*)Spotify Free": " ≤░ΥΘ ",
      "(.*)Steam": " ≤░ΥΥ "
    },
    "max-length": 64
  },

  // Weather Module Config
  "custom/weather": {
    "format": "{}┬░",
    "tooltip": true,
    "interval": 3600,
    "exec": "wttrbar --location ϊ╜βίπγ",
    "return-type": "json"
  },

  // Music Player Daemon Config
  "mpd": {
    "format": "{stateIcon} {consumeIcon}{randomIcon}{repeatIcon}{singleIcon}{artist} - {album} - {title} ({elapsedTime:%M:%S}/{totalTime:%M:%S}) ΎΑΒ",
    "format-disconnected": "Disconnected ΎΑΒ",
    "format-stopped": "{consumeIcon}{randomIcon}{repeatIcon}{singleIcon}Stopped ΎΑΒ",
    "interval": 10,
    "consume-icons": {
      "on": "ΎΔΕ " // Icon shows only when "consume" is on
    },
    "random-icons": {
      "off": "<span color=\"#f53c3c\">ΎΒ┤</span> ", // Icon grayed out when "random" is off
      "on": "ΎΒ┤ "
    },
    "repeat-icons": {
      "on": "ΎΑη "
    },
    "single-icons": {
      "on": "ΎΑη1 "
    },
    "state-icons": {
      "paused": "ΎΒΝ",
      "playing": "ΎΒΜ"
    },
    "tooltip-format": "MPD (connected)",
    "tooltip-format-disconnected": "MPD (disconnected)"
  },

  // Workspaces Config
  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "≤░χψ",
      "default": "Ό╗╛"
    },
    "all-outputs": false,
    "active-only": false,
    "on-click": "activate"
  },

  // Battery Config
  "battery": {
    "format": "{icon} {capacity}%",
    "interval": 5,
    "tooltip": false,
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format-full": "Charged ΎΔπ ",
    "format-icons": {
      "charging": ["≤░λε", "≤░ΓΗ", "≤░ΓΘ", "≤░ΓΙ", "≤░λζ", "≤░ΓΚ", "≤░λη", "≤░ΓΛ", "≤░ΓΜ", "≤░ΓΖ"],
      "default": ["≤░Β║", "≤░Β╗", "≤░Β╝", "≤░Β╜", "≤░Β╛", "≤░Β┐", "≤░ΓΑ", "≤░ΓΒ", "≤░ΓΓ", "≤░Β╣"]
    }
  },

  // Tray Config
  "tray": {
    "icon-size": 22,
    "rotate": 0,
    "spacing": 5
  },

  // Clock Config
  "clock": {
    "format": "{:%I:%M %p}",
    "rotate": 0,
    "format-alt": "{:%R ≤░Δφ %d┬╖%m┬╖%y}",
    "tooltip-format": "<tt>{calendar}</tt>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#ffead3'><b>{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b>{}</b></span>"
      }
    },
    "actions": {
      "on-click-right": "mode",
      "on-click-forward": "tz_up",
      "on-click-backward": "tx_down",
      "on-scroll-up": "shift_up",
      "on-scroll-down": "shift_down"
    }
  },

  // CPU Config
  "cpu": {
    "interval": 2,
    "format": "ΌΚο {usage}%",
    "tooltip": true
  },

  // Memory Config
  "memory": {
    "interval": 5,
    "format": "\uf538 {used}G",
    "max-length": 10,
    "tooltip": true,
    "tooltip-format": "RAM: {used}G / {total}G\nSwap: {swapUsed}G / {swapTotal}G"
  },

  // Network Config
  "network": {
    "interval": 5,
    "nospacing": 1,
    "format-wifi": "{icon}  {essid}",
    "format-icons": ["≤░νψ", "≤░νθ", "≤░νλ", "≤░νξ", "≤░νρ"],
    "format-ethernet": "≤░ΑΓ",
    "format-alt": "≤▒δΘ",
    "format-disconnected": "≤░Ψς",
    "tooltip-format-wifi": "{icon} {essid}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "tooltip-format-ethernet": "≤░ΑΓ  {ifname}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected"
  },

  // Pulseaudio Config
  "pulseaudio": {
    "scroll-step": 1,
    "format": "{volume}% {icon} ",
    "format-muted": "Ό╗ρ ",
    "format-bluetooth": "≤░Γ░ {volume}%",
    "format-icons": {
      "headphone": "ΎΑξ",
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "on-click": "pavucontrol",
    "ignored-sinks": ["AudioRelay Virtual Sink", "Recorder Sink"]
  },

  // Backlight Config
  "backlight": {
    "device": "intel_backlight",
    "format": "{icon} {percent}%",
    "format-icons": ["ΌΟΞ", "ΌΠΥ", "ΌΠΣ", "ΌΠΠ", "ΌΠΟ", "ΌΠΞ", "ΌΠΛ", "ΌΠΙ", "ΌΟδ"],
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-",
    "min-length": 6
  }
}
